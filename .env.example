# Database configuration
DATABASE_TYPE=postgres
DATABASE_URL=
# If DATABASE_URL is not used, provide the following values instead:
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password
DATABASE_NAME=studyhub
DATABASE=:memory:

# JWT configuration
JWT_ACCESS_SECRET=your_access_secret_at_least_16_chars
JWT_REFRESH_SECRET=your_refresh_secret_at_least_16_chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
SESSION_DURATION_DAYS=7
OTP_EXPIRATION_MINUTES=10
ACTIVE_USER_WINDOW_MINUTES=5
BCRYPT_SALT_ROUNDS=10

# Frontend and server config
FRONTEND_URL=http://localhost:3000
PORT=3001

# Redis (Upstash or local)
# For Upstash (TLS):
# REDIS_URL=redis://default:<token>@<host>.db.redis.io:14743
# For local Docker:
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Mail / email settings
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your_email_user
MAIL_CLIENT_ID=your_google_client_id
MAIL_CLIENT_SECRET=your_google_client_secret
MAIL_REFRESH_TOKEN=your_google_refresh_token
